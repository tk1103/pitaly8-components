import * as React from "react"
import { addPropertyControls, ControlType } from "framer"

/**
 * PITALY 8 - Professional Component Shell
 * このファイルは外部ロジックを読み込むためのインターフェースです。
 * ロジック本体は外部CDNに保護（難読化）して配置されています。
 */

// あなたのGitHubの配信URL
const EXTERNAL_SCRIPT_URL =
    "https://cdn.jsdelivr.net/gh/tk1103/pitaly8-components/component.js"

export default function PITALY8Shell(props) {
    const { enabled, direction, speed, smoothing } = props
    const containerRef = React.useRef<HTMLDivElement>(null)

    React.useEffect(() => {
        const container = containerRef.current
        if (!container) return

        let disposeFn: (() => void) | undefined

        // 外部スクリプトをダイナミックに読み込む
        const script = document.createElement("script")
        script.src = EXTERNAL_SCRIPT_URL
        script.type = "module"
        script.onload = () => {
            // 外部ファイル内の関数を実行（component.js内で定義されているもの）
            // @ts-ignore
            if (window.runPitaly8Component) {
                // @ts-ignore
                disposeFn = window.runPitaly8Component(container, {
                    enabled,
                    direction,
                    speed,
                    smoothing,
                })
            }
        }

        document.head.appendChild(script)

        return () => {
            if (disposeFn) disposeFn()
            if (script.parentNode) script.parentNode.removeChild(script)
        }
    }, [enabled, direction, speed, smoothing])

    return (
        <div
            ref={containerRef}
            style={{
                width: "100%",
                height: "100%",
                display: "flex",
                justifyContent: "center",
                alignItems: "center",
                overflow: "hidden",
                background: "transparent",
            }}
        />
    )
}

// 画像「image_741604.png」のプロパティパネルを再現
addPropertyControls(PITALY8Shell, {
    enabled: {
        title: "有効",
        type: ControlType.Boolean,
        defaultValue: true,
        enabledTitle: "Yes",
        disabledTitle: "No",
    },
    direction: {
        title: "方向",
        type: ControlType.Enum,
        options: ["Toward", "Away"],
        defaultValue: "Away",
        displaySegmentedControl: true,
    },
    speed: {
        title: "スピード",
        type: ControlType.Number,
        min: 0,
        max: 100,
        defaultValue: 50,
        unit: "%",
        displayStepper: true,
    },
    smoothing: {
        title: "平滑化",
        type: ControlType.Transition, // スライダー形式
        defaultValue: 70,
    },
    // ブランド表示用（リンク付き）
    brandInfo: {
        type: ControlType.String,
        title: " ",
        description: `More components at [PITALY 8](https://pitaly8.com)`,
    },
})

